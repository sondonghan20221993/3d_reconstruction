#ai_depth로 생성하는 코드

import os
import glob
import numpy as np
import depth_pro

INPUT_DIR = r"D:\epic\CitySample\airsim_dataset\grid_merge\rgb" # RGB 이미지가 있는 디렉토리
OUT_DIR   = r"D:\epic\CitySample\airsim_dataset\grid_merge\depth_pro" # 예측된 깊이 맵을 저장할 디렉토리

print("INPUT_DIR =", INPUT_DIR)
print("exists =", os.path.exists(INPUT_DIR))
print("isdir =", os.path.isdir(INPUT_DIR))

os.makedirs(OUT_DIR, exist_ok=True)

patterns = ["*.png", "*.jpg", "*.jpeg", "*.bmp", "*.webp"]
image_paths = []
for p in patterns:
    image_paths.extend(glob.glob(os.path.join(INPUT_DIR, p)))
    image_paths.extend(glob.glob(os.path.join(INPUT_DIR, p.upper())))

image_paths = sorted(image_paths)

print("total images:", len(image_paths))

model, transform = depth_pro.create_model_and_transforms()
model.eval()

for img_path in image_paths:
    name = os.path.splitext(os.path.basename(img_path))[0]
    out_path = os.path.join(OUT_DIR, name + ".npy")

    try:
        image, _, f_px = depth_pro.load_rgb(img_path)
        image = transform(image)

        prediction = model.infer(image, f_px=f_px)
        depth = prediction["depth"].cpu().numpy()

        np.save(out_path, depth)
        print(f"saved: {out_path} | shape={depth.shape}")

    except Exception as e:
        print(f"skip: {img_path} | error={e}")